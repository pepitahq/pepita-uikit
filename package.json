{
  "name": "@pepitahq/uikit",
  "version": "0.4.2",
  "description": "pepita's shared UI kit — design tokens, CSS primitives, and Svelte 5 components.",
  "license": "MIT",
  "author": "Zoltan Gobolos <zgobolos@barelynotable.com>",
  "type": "module",
  "repository": { "type": "git", "url": "git+https://github.com/pepitahq/pepita-uikit.git" },
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "svelte": "./dist/index.js" },
    "./theme.css": "./dist/styles/theme.css",
    "./tokens.css": "./dist/styles/tokens.css",
    "./primitives.css": "./dist/styles/primitives.css"
  },
  "files": ["dist"],
  "engines": { "node": ">=22" },
  "scripts": {
    "gen:theme": "node scripts/build-theme.mjs",
    "dev": "vite dev",
    "build": "vite build",
    "package": "svelte-kit sync && svelte-package && publint",
    "prepare": "svelte-kit sync && svelte-package",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run --passWithNoTests"
  },
  "peerDependencies": { "svelte": "^5" },
  "dependencies": { "phosphor-svelte": "^3.0.0" },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^3.0.0",
    "@sveltejs/kit": "^2.0.0",
    "@sveltejs/package": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/svelte": "^5.2.0",
    "jsdom": "^25.0.0",
    "publint": "^0.2.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
